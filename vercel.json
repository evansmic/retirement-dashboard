{
  "buildCommand": "npm run build:vercel-preview",
  "outputDirectory": "dist/react-app",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/intake", "destination": "/stable-intake.html" },
    { "source": "/stable-intake", "destination": "/stable-intake.html" },
    { "source": "/dashboard", "destination": "/retirement_dashboard.html" },
    { "source": "/retirement_dashboard", "destination": "/retirement_dashboard.html" },
    { "source": "/example/:slug", "destination": "/retirement_dashboard.html?example=:slug" }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
